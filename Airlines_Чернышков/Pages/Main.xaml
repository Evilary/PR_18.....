<Page x:Class="Airlines_Чернышков.Pages.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Airlines_Чернышков.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid Background="#FF0C73FE">
        <Label Content="Поиск дешевых авиабилетов" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,100,0,0" FontSize="26" FontWeight="Bold" Width="400"/>
        <Label Content="Лучший способ купить авиабилеты дешево" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,148,0,0" FontSize="15"/>

        <Label Content="Откуда:" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="202,193,0,0" FontWeight="Bold"/>
        <TextBox x:Name="from" Width="400" Height="25" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,225,0,0" />
        <Label Content="Куда:" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="202,259,0,0" RenderTransformOrigin="0.728,1.079" FontWeight="Bold"/>
        <TextBox x:Name="to" Width="400" Height="25" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,290,0,0" />

        <Button VerticalAlignment="Top" HorizontalAlignment="Right" Width="150" Height="35" Content="Найти" Margin="0,335,200,0" Foreground="White" Background="#FFFF4600" FontWeight="Bold" FontSize="15" Click="Search" />
    </Grid>
</Page>
